# ========================================
# DATABASE CONFIGURATION
# ========================================
# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/database_name?schema=public"

# ========================================
# NEXTAUTH CONFIGURATION
# ========================================
# Application URL (http://localhost:3000 for local, https://domain.com for production)
NEXTAUTH_URL=http://localhost:3000

# NextAuth secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-here-minimum-32-characters

# ========================================
# APPLICATION CONFIGURATION
# ========================================
NODE_ENV=production
PORT=3000

# ========================================
# FILE UPLOAD CONFIGURATION (Local Storage)
# ========================================
# Directory for uploaded files
UPLOAD_DIR=/opt/tapchi-hcqs/uploads

# Maximum file size in bytes (10MB = 10485760)
MAX_FILE_SIZE=10485760

# ========================================
# EMAIL CONFIGURATION (Optional)
# ========================================
# SMTP server settings
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Sender information
# FROM_EMAIL=noreply@tapchi-hcqs.vn
# FROM_NAME="Tạp chí Khoa học Hậu cần Quân sự"

# ========================================
# SECURITY CONFIGURATION
# ========================================
# Password hashing rounds (10-12 recommended)
BCRYPT_ROUNDS=10

# JWT token expiration
JWT_EXPIRES_IN=24h

# Refresh token expiration
REFRESH_TOKEN_EXPIRES_IN=30d

# ========================================
# LOGGING CONFIGURATION
# ========================================
# Log level: error, warn, info, debug
LOG_LEVEL=info

# ========================================
# RATE LIMITING
# ========================================
# API rate limit (requests per minute)
# RATE_LIMIT_PER_MINUTE=100

# ========================================
# CORS CONFIGURATION
# ========================================
# Allowed origins (comma separated)
# CORS_ORIGIN=http://localhost:3000,https://yourdomain.com

# ========================================
# NOTES
# ========================================
# 1. Never commit this file with real credentials
# 2. Copy to .env and fill in your actual values
# 3. Keep .env file secure and never share it
# 4. For Gmail SMTP:
#    - Enable 2FA
#    - Create App Password at: https://myaccount.google.com/apppasswords
# 5. Generate secure secrets:
#    - openssl rand -base64 32
#    - node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
