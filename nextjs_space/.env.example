# ============================================================================
# TẠP CHÍ NGHỆ THUẬT QUÂN SỰ VIỆT NAM (NTQS) — MẪU CẤU HÌNH MÔI TRƯỜNG
# ----------------------------------------------------------------------------
# Đây là FILE MẪU (không chứa secret thật). KHÔNG sửa file này để chạy app.
# Cách dùng đúng: chạy `bash setup.sh` (hoặc `npm run setup:env`) — script sẽ
# HỎI các giá trị cần khai báo và TỰ SINH các secret, rồi ghi ra file `.env`.
#
# Nếu muốn tạo `.env` thủ công: copy file này thành `.env` và điền giá trị.
#   cp .env.example .env
#
# Quy tắc nhận diện (xem .claude/rules/journal-identity.md):
#   - DATABASE_URL phải trỏ DB RIÊNG (gợi ý: tapchi_ntqs), KHÔNG dùng chung
#     với tapchi-hcqs.
#   - App chạy cổng 3001 để không đụng tapchi-hcqs (cổng 3000).
# ============================================================================

# ===========================================================
# 🌐 [BẮT BUỘC] DATABASE — PostgreSQL riêng cho NTQS
# ===========================================================
# Định dạng: postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public
DATABASE_URL="postgresql://tapchi_ntqs:CHANGE_ME@localhost:5432/tapchi_ntqs?schema=public"

# ===========================================================
# 🔐 [BẮT BUỘC] AUTH & URL
# ===========================================================
NEXTAUTH_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Các secret BÊN DƯỚI để TRỐNG — installer tự sinh (openssl/crypto randomBytes).
# Nếu điền tay: NEXTAUTH/JWT dùng `openssl rand -base64 32`,
#               ORCID_ENCRYPTION_KEY/CRON_SECRET dùng chuỗi hex 32-byte.
NEXTAUTH_SECRET=""
JWT_SECRET=""
JWT_REFRESH_SECRET=""
ORCID_ENCRYPTION_KEY=""
CRON_SECRET=""

# ===========================================================
# 📂 [BẮT BUỘC] LƯU TRỮ FILE
# ===========================================================
# USE_AWS=false → lưu local vào UPLOAD_ROOT (mặc định, phù hợp air-gap).
USE_AWS="false"
UPLOAD_ROOT="./public/uploads"
# MAX_VIDEO_UPLOAD_MB=0 nghĩa là KHÔNG giới hạn dung lượng video.
MAX_VIDEO_UPLOAD_MB="0"

# Chỉ dùng khi USE_AWS="true" (để trống khi lưu local):
AWS_REGION="us-west-2"
AWS_BUCKET_NAME=""
AWS_FOLDER_PREFIX=""

# ===========================================================
# ⚙️ [BẮT BUỘC] HỆ THỐNG
# ===========================================================
# development | production
NODE_ENV="development"
PORT="3001"
# Bật log query Prisma / debug khi cần (production nên để "false").
PRISMA_LOG_QUERIES="false"
DEBUG="false"

# ===========================================================
# 🔗 [TÙY CHỌN] DỊCH VỤ NGOÀI — TẮT MẶC ĐỊNH (bắt buộc TẮT khi air-gap)
# ===========================================================
# ORCID (đăng nhập/định danh tác giả qua internet):
ORCID_SANDBOX="true"
# ORCID_CLIENT_ID=""
# ORCID_CLIENT_SECRET=""
# ORCID_REDIRECT_URI=""

# Crossref (đăng ký DOI qua internet):
CROSSREF_TEST_MODE="true"
# DOI_PREFIX=""
# CROSSREF_DEPOSITOR_NAME=""
# CROSSREF_DEPOSITOR_EMAIL=""

# iThenticate (đạo văn qua internet — air-gap dùng engine nội bộ, để "false"):
ITHENTICATE_ENABLED="false"
# ITHENTICATE_API_KEY=""
# ITHENTICATE_API_URL=""

# ===========================================================
# 📧 [TÙY CHỌN] SMTP — gửi email thông báo
# ===========================================================
# SMTP_ENABLED="false" → app vẫn chạy bình thường, chỉ không gửi email.
SMTP_ENABLED="false"
# Khi bật, điền sender đúng tên tạp chí NTQS:
# SMTP_HOST=""
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_SECURE="false"
# SMTP_FROM_NAME="Tạp chí Nghệ thuật Quân sự Việt Nam"
# SMTP_FROM_EMAIL="tapchintqsvn@gmail.com"

# ===========================================================
# 🧰 [TÙY CHỌN] REDIS / RATE-LIMIT (Upstash)
# ===========================================================
# Để trống → tự fallback rate-limit in-memory (đủ dùng cho air-gap/đơn máy).
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ===========================================================
# 🔔 [TÙY CHỌN] WEB PUSH (VAPID)
# ===========================================================
# Sinh bằng: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""
# VAPID_SUBJECT="mailto:tapchintqsvn@gmail.com"

# ===========================================================
# 🖨️ [TÙY CHỌN] XUẤT PDF (Puppeteer/Chromium)
# ===========================================================
# Air-gap: trỏ tới chromium bundled trong node_modules (@sparticuz/chromium),
# installer profile --airgap sẽ tự điền giá trị này.
# PUPPETEER_EXECUTABLE_PATH=""
